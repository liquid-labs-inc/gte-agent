{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "gte-agent",
  "description": "GTE Agent runtime skeleton",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run --cwd packages/cli dev",
    "audit:gte": "bun run script/audit-gte-imports.ts",
    "lint": "oxlint",
    "typecheck": "bun turbo typecheck",
    "upgrade-opentui": "bun run script/upgrade-opentui.ts",
    "postinstall": "bun run --cwd packages/core fix-node-pty",
    "prepare": "husky",
    "test": "echo 'do not run tests from root' && exit 1"
  },
  "workspaces": {
    "packages": [
      "packages/core",
      "packages/llm",
      "packages/server",
      "packages/cli",
      "packages/plugin",
      "packages/script",
      "packages/http-recorder",
      "packages/effect-drizzle-sqlite",
      "packages/effect-sqlite-node",
      "packages/sdk/js",
      "packages/tui",
      "packages/gte-ts"
    ],
    "catalog": {
      "@effect/opentelemetry": "4.0.0-beta.74",
      "@effect/platform-node": "4.0.0-beta.74",
      "@effect/sql-sqlite-bun": "4.0.0-beta.74",
      "@npmcli/arborist": "9.4.0",
      "@types/bun": "1.3.13",
      "@types/cross-spawn": "6.0.6",
      "@hono/standard-validator": "0.2.0",
      "@hono/zod-validator": "0.4.2",
      "@opentui/core": "0.3.2",
      "@opentui/keymap": "0.3.2",
      "@opentui/solid": "0.3.2",
      "ulid": "3.0.1",
      "@types/luxon": "3.7.1",
      "@types/node": "24.12.2",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@pierre/diffs": "1.1.0-beta.18",
      "opentui-spinner": "0.0.6",
      "diff": "8.0.2",
      "drizzle-kit": "1.0.0-rc.2",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "4.0.0-beta.74",
      "ai": "6.0.168",
      "cross-spawn": "7.0.6",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "remend": "1.3.0",
      "semver": "7.7.4",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "vite": "7.1.4",
      "solid-js": "1.9.10",
      "@lydell/node-pty": "1.2.0-beta.12"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/mime-types": "3.0.1",
    "@typescript/native-preview": "catalog:",
    "glob": "13.0.5",
    "husky": "9.1.7",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.6.2",
    "semver": "^7.6.0",
    "turbo": "2.8.13"
  },
  "dependencies": {
    "@gte-agent/script": "workspace:*",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gte/gte-agent"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "tree-sitter-powershell",
    "web-tree-sitter"
  ],
  "overrides": {
    "@opentui/core": "catalog:",
    "@opentui/keymap": "catalog:",
    "@opentui/solid": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  },
  "patchedDependencies": {
    "@npmcli/agent@4.0.0": "patches/@npmcli%2Fagent@4.0.0.patch",
    "@silvia-odwyer/photon-node@0.3.4": "patches/@silvia-odwyer%2Fphoton-node@0.3.4.patch",
    "@standard-community/standard-openapi@0.2.9": "patches/@standard-community%2Fstandard-openapi@0.2.9.patch",
    "solid-js@1.9.10": "patches/solid-js@1.9.10.patch",
    "@ai-sdk/xai@3.0.82": "patches/@ai-sdk%2Fxai@3.0.82.patch",
    "gcp-metadata@8.1.2": "patches/gcp-metadata@8.1.2.patch",
    "pacote@21.5.0": "patches/pacote@21.5.0.patch",
    "@ai-sdk/google@3.0.73": "patches/@ai-sdk%2Fgoogle@3.0.73.patch"
  }
}
